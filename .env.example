# Required for Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cookie signing secret (required in production; optional in dev).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Base URL for OAuth callbacks (required in production; optional in dev)
APP_URL="http://localhost:3000"

# Optional integrations
GITHUB_TOKEN=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
