# Node modules (will be installed in container)
node_modules/

# Build outputs (except dist - needed for production image)
build/
coverage/

# Environment files (should be passed at runtime)
.env*
!.env.example

# Git files
.git/
.gitignore
.github/

# IDE and OS files
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino-*.log

# Testing
coverage/

# Vite cache
.vite-cache/

# Metadata
metadata.json

# Documentation (not needed in container)
*.md
!README.md

# Docker files (not needed inside container)
Dockerfile
.dockerignore
docker-compose.yml
